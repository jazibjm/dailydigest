# Copy this file to .env and fill in real values. NEVER commit .env.

# ---- Database ----
# Local Postgres (matches docker-compose.yml) or a Neon connection string.
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/techdigest

# ---- OpenAI ----
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4.1-mini

# ---- Pipeline tuning ----
NUM_STORIES=15
MAX_CHARS=2000

# ---- RSS feeds (comma-separated; add a URL to add a feed) ----
RSS_FEEDS=https://feeds.arstechnica.com/arstechnica/index,https://techcrunch.com/feed/,https://www.theverge.com/rss/index.xml,https://www.wired.com/feed/rss,https://www.pcmag.com/feeds/rss/news,https://www.technologyreview.com/feed/

# ---- Discord delivery (leave blank to skip Discord) ----
DISCORD_WEBHOOK_URL=

# ---- API / CORS (comma-separated origins allowed to call the API) ----
# In production set this to your Vercel domain, e.g. https://yourapp.vercel.app
ALLOWED_ORIGINS=http://localhost:3000
